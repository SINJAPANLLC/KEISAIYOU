modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
SQUARE_ENV = "production"
APP_BASE_URL = "https://keisaiyou-sinjapan.com"
SITE_URL = "https://keisaiyou-sinjapan.com"
SMTP_HOST = "smtp.hostinger.com"
SMTP_PORT = "465"
SMTP_USER = "info@keisaiyou-sinjapan.com"
SMTP_FROM = "info@keisaiyou-sinjapan.com"
SMTP_SECURE = "true"
